# Локальная среда (Task 0004). Скопировать в .env — `make dev` делает это автоматически.
# Секреты в репозитории не хранятся (FOUNDATION §11); .env — в .gitignore.
POSTGRES_USER=hospitality
POSTGRES_PASSWORD=hospitality
POSTGRES_DB=hospitality
POSTGRES_PORT=5432

REDIS_PORT=6379

APP_PORT=8000

# Аутентификация HTTP API (Task 0013, FOUNDATION §11): статический сервисный
# токен Phase 0. Запрос к /api/v1/* обязан нести заголовок
# `Authorization: Bearer <SERVICE_TOKEN>`; токен привязан к тенанту по slug.
SERVICE_TOKEN=dev-service-token
SERVICE_TOKEN_TENANT_SLUG=demo-hotel

# AI Gateway (Task 0014, FOUNDATION §7.2): ключ Anthropic (пустой — валидно
# для локальной разработки и тестов: они ходят в MockLlmProvider), модель
# (одна, без маршрутизации), таймаут одного вызова (сек), число попыток
# (ретрай только по таймауту) и дневной бюджет LLM на тенанта в USD
# (UTC-сутки; превышение — отказ ERR-AI-002).
ANTHROPIC_API_KEY=
# Модель гостевого диалога. Sonnet 5 по ADR-012: bake-off (ADR-010) выбирал
# Haiku 4.5 как равный по качеству, но живая проверка staging показала срыв Haiku
# в русский на казахском (#60/#61) — на рынке РК это блокер. ADR-012 переопределяет
# выбор для гостевого диалога; staging уже дефолтит на claude-sonnet-5.
LLM_MODEL=claude-sonnet-5
LLM_TIMEOUT_SECONDS=30.0
LLM_MAX_ATTEMPTS=3
LLM_TENANT_DAILY_BUDGET_USD=5.0

# Канал Telegram (Task 0016, FOUNDATION §8.4). TELEGRAM_WEBHOOK_SECRET — секрет
# вебхука: Telegram шлёт его в заголовке X-Telegram-Bot-Api-Secret-Token (задаётся
# при setWebhook); ПУСТОЙ = вебхук закрыт и отвергает всё (fail-closed). Локально
# без бота можно оставить пустым — тесты подставляют фейк-отправитель. Регистрация
# вебхука и генерация секрета — docs/runbooks/telegram.md. TELEGRAM_BOT_TOKEN —
# токен бота от BotFather для отправки ответов. TELEGRAM_TENANT_SLUG — какому
# тенанту принадлежит чат (Phase 0: один бот = демо-тенант). TELEGRAM_STAFF_CHAT_ID
# (Task 0017) — chat.id staff-чата службы: туда идут уведомления о новых заявках,
# там персонал закрывает их командами /assign|/start|/done|/cancel <id>. ПУСТОЙ =
# уведомления службе выключены (на staging для сквозного скелета — обязателен).
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_BOT_TOKEN=
TELEGRAM_TENANT_SLUG=demo-hotel
TELEGRAM_STAFF_CHAT_ID=

# Уровень логирования приложения (Task 0007): DEBUG | INFO | WARNING | ERROR.
# ВНИМАНИЕ: WARNING и выше отключает событие http_request (уровень INFO) —
# поиск следа запроса по correlation id в логах перестанет находить записи.
LOG_LEVEL=INFO

# Воркер доменных событий (Task 0010, ADR-005): период опроса outbox при
# пустой очереди (сек), размер пачки за итерацию, предел попыток доставки
# одного события (исчерпание — ERR-EVENTS-002 в docs/runbooks/errors.md).
WORKER_POLL_INTERVAL_SECONDS=1.0
WORKER_BATCH_SIZE=50
WORKER_MAX_DELIVERY_ATTEMPTS=10

# Backoff между попытками доставки одного события (issue #18, ADR-009):
# после неудачи следующая попытка — не раньше, чем через
# min(WORKER_RETRY_BACKOFF_BASE_SECONDS * 2**(attempts-1), WORKER_RETRY_BACKOFF_MAX_SECONDS).
WORKER_RETRY_BACKOFF_BASE_SECONDS=2.0
WORKER_RETRY_BACKOFF_MAX_SECONDS=300.0

# Retention обработанных строк outbox_events (issue #18, ADR-009, FOUNDATION §9):
# сколько дней хранить доставленные (processed_at IS NOT NULL) строки и как
# часто воркер проверяет, не пора ли их удалить.
OUTBOX_RETENTION_DAYS=30
WORKER_CLEANUP_INTERVAL_SECONDS=3600.0
