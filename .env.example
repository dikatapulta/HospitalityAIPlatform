# Локальная среда (Task 0004). Скопировать в .env — `make dev` делает это автоматически.
# Секреты в репозитории не хранятся (FOUNDATION §11); .env — в .gitignore.
POSTGRES_USER=hospitality
POSTGRES_PASSWORD=hospitality
POSTGRES_DB=hospitality
POSTGRES_PORT=5432

REDIS_PORT=6379

APP_PORT=8000

# Аутентификация HTTP API (Task 0013, FOUNDATION §11): статический сервисный
# токен Phase 0. Запрос к /api/v1/* обязан нести заголовок
# `Authorization: Bearer <SERVICE_TOKEN>`; токен привязан к тенанту по slug.
SERVICE_TOKEN=dev-service-token
SERVICE_TOKEN_TENANT_SLUG=demo-hotel

# Уровень логирования приложения (Task 0007): DEBUG | INFO | WARNING | ERROR.
# ВНИМАНИЕ: WARNING и выше отключает событие http_request (уровень INFO) —
# поиск следа запроса по correlation id в логах перестанет находить записи.
LOG_LEVEL=INFO

# Воркер доменных событий (Task 0010, ADR-005): период опроса outbox при
# пустой очереди (сек), размер пачки за итерацию, предел попыток доставки
# одного события (исчерпание — ERR-EVENTS-002 в docs/runbooks/errors.md).
WORKER_POLL_INTERVAL_SECONDS=1.0
WORKER_BATCH_SIZE=50
WORKER_MAX_DELIVERY_ATTEMPTS=10

# Backoff между попытками доставки одного события (issue #18, ADR-009):
# после неудачи следующая попытка — не раньше, чем через
# min(WORKER_RETRY_BACKOFF_BASE_SECONDS * 2**(attempts-1), WORKER_RETRY_BACKOFF_MAX_SECONDS).
WORKER_RETRY_BACKOFF_BASE_SECONDS=2.0
WORKER_RETRY_BACKOFF_MAX_SECONDS=300.0

# Retention обработанных строк outbox_events (issue #18, ADR-009, FOUNDATION §9):
# сколько дней хранить доставленные (processed_at IS NOT NULL) строки и как
# часто воркер проверяет, не пора ли их удалить.
OUTBOX_RETENTION_DAYS=30
WORKER_CLEANUP_INTERVAL_SECONDS=3600.0
