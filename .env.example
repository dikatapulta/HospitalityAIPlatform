# Локальная среда (Task 0004). Скопировать в .env — `make dev` делает это автоматически.
# Секреты в репозитории не хранятся (FOUNDATION §11); .env — в .gitignore.
POSTGRES_USER=hospitality
POSTGRES_PASSWORD=hospitality
POSTGRES_DB=hospitality
POSTGRES_PORT=5432

REDIS_PORT=6379

APP_PORT=8000

# Уровень логирования приложения (Task 0007): DEBUG | INFO | WARNING | ERROR.
# ВНИМАНИЕ: WARNING и выше отключает событие http_request (уровень INFO) —
# поиск следа запроса по correlation id в логах перестанет находить записи.
LOG_LEVEL=INFO

# Воркер доменных событий (Task 0010, ADR-005): период опроса outbox при
# пустой очереди (сек), размер пачки за итерацию, предел попыток доставки
# одного события (исчерпание — ERR-EVENTS-002 в docs/runbooks/errors.md).
WORKER_POLL_INTERVAL_SECONDS=1.0
WORKER_BATCH_SIZE=50
WORKER_MAX_DELIVERY_ATTEMPTS=10
