# Секреты staging — заполняются ТОЛЬКО на сервере, в репозиторий не коммитятся
# (FOUNDATION §11). На VPS: cp .env.staging.example .env && отредактировать .env.
# Чеклист и ротация — docs/runbooks/secrets.md.
POSTGRES_USER=hospitality
POSTGRES_PASSWORD=ЗАМЕНИ_НА_СЛУЧАЙНЫЙ_ПАРОЛЬ   # напр. openssl rand -hex 24
POSTGRES_DB=hospitality

# Порт, на котором приложение слушает на VPS (наружу; в проде — за reverse-proxy).
APP_PORT=8000
