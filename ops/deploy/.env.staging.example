# Секреты staging — заполняются ТОЛЬКО на сервере, в репозиторий не коммитятся
# (FOUNDATION §11). На VPS: cp .env.staging.example .env && отредактировать .env.
# Чеклист и ротация — docs/runbooks/secrets.md.
POSTGRES_USER=hospitality
POSTGRES_PASSWORD=ЗАМЕНИ_НА_СЛУЧАЙНЫЙ_ПАРОЛЬ   # напр. openssl rand -hex 24
POSTGRES_DB=hospitality

# Порт, на котором приложение слушает на VPS (наружу; в проде — за reverse-proxy).
APP_PORT=8000

# Уровень логирования приложения: DEBUG | INFO | WARNING | ERROR (см. .env.example
# в корне репозитория — WARNING отключает след запросов http_request).
LOG_LEVEL=INFO

# Сервисный токен HTTP API (Task 0013, FOUNDATION §11): им аутентифицируются
# запросы к /api/v1/*; привязан к тенанту demo-hotel. Сгенерировать:
# openssl rand -hex 32. Dev-значение по умолчанию на staging НЕ использовать.
SERVICE_TOKEN=ЗАМЕНИ_НА_СЛУЧАЙНЫЙ_ТОКЕН
SERVICE_TOKEN_TENANT_SLUG=demo-hotel

# AI Gateway (Task 0014, FOUNDATION §7.2): ключ Anthropic для боевых вызовов
# LLM. Пока оркестратора нет (Task 0015), можно оставить пустым — приложение
# работает; первый AI-вызов без ключа упадёт понятной ошибкой конфигурации.
ANTHROPIC_API_KEY=

# Канал Telegram (Task 0016, FOUNDATION §8.4). TELEGRAM_WEBHOOK_SECRET — секрет
# вебхука: сгенерировать `openssl rand -hex 32` и передать его же в secret_token
# при setWebhook (docs/runbooks/telegram.md). ПУСТОЙ = вебхук закрыт, отвергает
# всё. TELEGRAM_BOT_TOKEN — токен бота от BotFather (для отправки ответов).
# TELEGRAM_STAFF_CHAT_ID (Task 0017) — chat.id staff-чата: уведомления о заявках +
# команды закрытия /assign|/start|/done|/cancel; пустой = служба-канал выключен.
# Как узнать chat.id: добавить бота в чат и посмотреть getUpdates (runbook telegram.md).
TELEGRAM_WEBHOOK_SECRET=ЗАМЕНИ_НА_СЛУЧАЙНЫЙ_СЕКРЕТ
TELEGRAM_BOT_TOKEN=ЗАМЕНИ_НА_ТОКЕН_БОТА_ОТ_BOTFATHER
TELEGRAM_TENANT_SLUG=demo-hotel
TELEGRAM_STAFF_CHAT_ID=ЗАМЕНИ_НА_CHAT_ID_STAFF_ЧАТА

# Наблюдаемость (Task 0018, FOUNDATION §10.4, §10.8). SENTRY_DSN — DSN проекта
# Sentry (Settings → Client Keys в sentry.io); ПУСТОЙ = Sentry выключен.
# TELEGRAM_ALERT_BOT_TOKEN — токен бота для алертов (можно тот же, что
# TELEGRAM_BOT_TOKEN: тот же бот, другой чат). TELEGRAM_ALERT_CHAT_ID — chat.id
# Telegram-канала команды (бот добавлен в канал администратором; как узнать id —
# docs/runbooks/alerts.md). Оба пустые = алертер пассивен (WARNING в логах);
# заполнен только один — алертер падает с ошибкой конфигурации.
SENTRY_DSN=
TELEGRAM_ALERT_BOT_TOKEN=
TELEGRAM_ALERT_CHAT_ID=

# Строку APP_IMAGE=... сюда писать не нужно: её ведёт deploy.sh — после каждого
# успешного деплоя записывает в .env последний здоровый образ, чтобы ручные
# `docker compose ...`-команды из runbook'ов работали без подготовки.
